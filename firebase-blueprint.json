{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile representation",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "medicalHistory": { "type": "string" }
      },
      "required": ["uid", "email", "displayName", "role", "createdAt"]
    },
    "DoctorAvailability": {
      "title": "DoctorAvailability",
      "description": "Real-time doctor presence state",
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "statusText": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "nextAvailableTime": { "type": "string" },
        "estimatedWaitTimeMinutes": { "type": "number" },
        "queueCount": { "type": "number" }
      },
      "required": ["status", "statusText"]
    },
    "Service": {
      "title": "Service",
      "description": "Dental services details Offered",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "duration": { "type": "number" },
        "estimatedCost": { "type": "string" },
        "benefits": { "type": "array" },
        "recoveryTime": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "ClinicTiming": {
      "title": "ClinicTiming",
      "description": "Daily operational timings of clinic",
      "type": "object",
      "properties": {
        "day": { "type": "string" },
        "open": { "type": "string" },
        "close": { "type": "string" },
        "isClosed": { "type": "boolean" }
      },
      "required": ["day", "open", "close", "isClosed"]
    },
    "FAQ": {
      "title": "FAQ",
      "description": "Frequently Asked Questions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "question", "answer"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Patient reviews and comments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["id", "name", "rating", "comment"]
    },
    "Blog": {
      "title": "Blog",
      "description": "Informative posts written by doctors",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "author": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content"]
    },
    "Gallery": {
      "title": "Gallery",
      "description": "Photos of clinic facilities and equipment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["id", "title", "image"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Clinic contact details and config",
      "type": "object",
      "properties": {
        "clinicName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "whatsapp": { "type": "string" },
        "emergencyPhone": { "type": "string" },
        "address": { "type": "string" },
        "googleMapsEmbed": { "type": "string" }
      },
      "required": ["clinicName", "phone", "email", "address"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Homepage banner announcements",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "active"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled dental appointments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "patientName", "serviceId", "serviceName", "dateTime", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Inquiries from the contact page",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone", "message"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Real-time updates sent to patients or doctors",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Clinic user profiles"
    },
    "/doctorAvailability/{id}": {
      "schema": "DoctorAvailability",
      "description": "Doctor status indicators"
    },
    "/services/{id}": {
      "schema": "Service",
      "description": "Offered clinical services"
    },
    "/clinicTimings/{id}": {
      "schema": "ClinicTiming",
      "description": "Clinic operation timings"
    },
    "/FAQs/{id}": {
      "schema": "FAQ",
      "description": "Frequently Asked Questions"
    },
    "/testimonials/{id}": {
      "schema": "Testimonial",
      "description": "Patient testimonials"
    },
    "/blogs/{id}": {
      "schema": "Blog",
      "description": "Doctor blogs"
    },
    "/gallery/{id}": {
      "schema": "Gallery",
      "description": "Clinic facility image showcase"
    },
    "/settings/{id}": {
      "schema": "Settings",
      "description": "Clinic core configuration settings"
    },
    "/announcements/{id}": {
      "schema": "Announcement",
      "description": "Clinic home status banners"
    },
    "/appointments/{id}": {
      "schema": "Appointment",
      "description": "Patient booked appointments"
    },
    "/messages/{id}": {
      "schema": "Message",
      "description": "Contact message queries"
    },
    "/notifications/{id}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
